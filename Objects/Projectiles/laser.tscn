[sub_resource type="GDScript" id="GDScript_rgfps"]
script/source = "extends Node2D


@onready var direction: Vector2 = Vector2.from_angle(rotation-PI/2)
@onready var projectile: Sprite2D = $projectile
@onready var despawn_timer: Timer = $DespawnTimer
const speed = 500

func _ready():
	despawn_timer.connect(\"timeout\", queue_free)

func _process(delta: float) -> void:
	global_position += direction * delta * speed
	projectile.position.y = (delta * speed)-2

func _on_collision_detector_body_entered(_body: Node2D) -> void:
	visible = false
	call_deferred(\"queue_free\")
"

